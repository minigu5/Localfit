{
  "rules": {
    "telemetry": {
      ".read": true,
      ".indexOn": ["recorded_at"],
      "$event": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['ram_gb', 'unified_memory', 'model_installed', 'engine', 'benchmark_version', 'recorded_at', 'tokens_per_sec']) && newData.child('engine').val() == 'ollama' && newData.child('benchmark_version').val() >= 1 && newData.child('benchmark_version').val() <= 4",
        "ram_gb": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 1024"
        },
        "vram_gb": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 512)"
        },
        "unified_memory": {
          ".validate": "newData.isBoolean()"
        },
        "gpu_tflops": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000)"
        },
        "model_installed": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 512"
        },
        "model_repo_id": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 512)"
        },
        "model_size_bytes": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() > 0 && newData.val() <= 1099511627776)"
        },
        "engine": {
          ".validate": "newData.val() == 'ollama'"
        },
        "benchmark_version": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 4"
        },
        "recorded_at": {
          ".validate": "newData.isString() && newData.val().length >= 20 && newData.val().length <= 50"
        },
        "tokens_per_sec": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
        },
        "sample_count": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 10)"
        },
        "tokens_per_sec_min": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000)"
        },
        "tokens_per_sec_max": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000)"
        },
        "runtime_profile": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 32)"
        },
        "context_length": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 256 && newData.val() <= 131072)"
        },
        "gpu_offload_percent": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 100)"
        },
        "cpu_threads": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 1024)"
        },
        "num_batch": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 65536)"
        },
        "os": {
          ".validate": "newData.parent().child('benchmark_version').val() < 3 && newData.isString() && newData.val().length <= 128"
        },
        "cpu": {
          ".validate": "newData.parent().child('benchmark_version').val() < 3 && newData.isString() && newData.val().length <= 256"
        },
        "gpu": {
          ".validate": "newData.parent().child('benchmark_version').val() < 3 && newData.isString() && newData.val().length <= 256"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
